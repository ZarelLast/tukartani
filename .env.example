# ===========================================
# Environment Variables untuk Tukar Tani
# ===========================================

# Google Gemini API Key (required)
# Dapatkan dari: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional, default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Server Port (optional, default: 8080)
# Cloud Run akan set ini secara otomatis
PORT=8080

# Node Environment (optional)
NODE_ENV=production
